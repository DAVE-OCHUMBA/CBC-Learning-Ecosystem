  "shortcuts": [
    {
      "name": "Student Portal",
      "short_name": "Student",
      "description": "Access student dashboard",
      "url": "/student/dashboard",
      "icons": [
        {
          "src": "/assets/icons/student.png",
          "sizes": "96x96"
        }
      ]
    },
    {
      "name": "Teacher Portal",
      "short_name": "Teacher",
      "description": "Access teacher dashboard",
      "url": "/teacher/dashboard",
      "icons": [
        {
          "src": "/assets/icons/teacher.png",
          "sizes": "96x96"
        }
      ]
    },
    {
      "name": "Parent Portal",
      "short_name": "Parent",
      "description": "Access parent dashboard",
      "url": "/parent/dashboard",
      "icons": [
        {
          "src": "/assets/icons/parent.png",
          "sizes": "96x96"
        }
      ]
    },
    {
      "name": "Pay Fees",
      "short_name": "Pay",
      "description": "Pay school fees via M-Pesa",
      "url": "/parent/payments",
      "icons": [
        {
          "src": "/assets/icons/payment.png",
          "sizes": "96x96"
        }
      ]
    }
  ],
  "related_applications": [],
  "prefer_related_applications": false,
  "iarc_rating_id": "",
  "share_target": {
    "action": "/share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "file",
          "accept": [
            "image/*",
            "application/pdf",
            "application/vnd.ms-excel",
            "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet"
          ]
        }
      ]
    }
  },
  "protocol_handlers": [
    {
      "protocol": "web+cbc",
      "url": "/app?target=%s"
    }
  ],
  "launch_handler": {
    "client_mode": ["navigate-existing", "auto"]
  },
  "edge_side_panel": {
    "preferred_width": 400
  }
}
